# -----------------------------------------------------------------------------
# Frontend (Vite)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Leave empty when frontend and API are served from the same origin.
VITE_API_BASE_URL=
VITE_SITE_URL=http://localhost:5173

# Optional local admin bypass (development only).
VITE_ENABLE_ADMIN_BYPASS=false
VITE_ADMIN_EMAIL=
VITE_ADMIN_PASSWORD=

# Storage buckets
VITE_CONTRACTS_BUCKET=contracts
VITE_CONTRACTOR_PHOTOS_BUCKET=contractor-photos
VITE_PROPERTY_IMAGES_BUCKET=property-images

# Stripe frontend
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_STRIPE_CHECKOUT_ENDPOINT=/api/create-checkout
VITE_STRIPE_CONFIRM_ENDPOINT=/api/confirm-checkout
VITE_STRIPE_CONNECT_ACCOUNT_ENDPOINT=/api/stripe-connect-account-link
VITE_STRIPE_ESCROW_CREATE_ENDPOINT=/api/stripe-escrow-create
VITE_STRIPE_ESCROW_RELEASE_ENDPOINT=/api/stripe-escrow-release

# Stripe frontend price IDs
VITE_STRIPE_PRICE_CONTRACTOR_BASIC_MONTHLY=
VITE_STRIPE_PRICE_CONTRACTOR_PRO_MONTHLY=
VITE_STRIPE_PRICE_DEALMAKER_MONTHLY=
VITE_STRIPE_PRICE_REALTOR_MONTHLY=
VITE_STRIPE_PRICE_CREDITS_STARTER=
VITE_STRIPE_PRICE_CREDITS_GROWTH=
VITE_STRIPE_PRICE_CREDITS_PRO=

# App feature endpoints
VITE_EXECUTED_CONTRACT_WEBHOOK_URL=/api/notify-contract
VITE_CONTRACT_SIGNATURE_ATTESTATION_ENDPOINT=/api/contracts-signature-attestation
VITE_CONTRACTS_PDF_ENDPOINT=/api/contracts-generate-pdf
VITE_REQUIRE_CSLB_VERIFICATION=true
VITE_CSLB_VERIFY_ENDPOINT=/api/cslb-verify
VITE_PUSH_TOKEN_ENDPOINT=/api/mobile-push-token
VITE_TITLE_PORTAL_ADMIN_ENDPOINT=/api/title-portal-admin
VITE_PARTNER_TRACKING_ENDPOINT=/api/partner-referral-event
VITE_LEAD_LISTINGS_ENDPOINT=/api/lead-listings
VITE_SEND_SMS_ENDPOINT=/api/send-sms

# Twilio frontend / dialer
VITE_TWILIO_ACCESS_TOKEN_ENDPOINT=/api/twilio-access-token
VITE_TWILIO_ACCOUNT_SID=
VITE_ALLOW_DIALER_SIMULATION=false
VITE_DIALER_CSV_MAX_ROWS=2000
VITE_DIALER_CSV_MAX_FILE_BYTES=1500000

# Mobile flags
VITE_CAPACITOR_ENABLED=false
VITE_CAPACITOR_PUSH_ENABLED=false
VITE_CAPACITOR_CAMERA_ENABLED=true
VITE_PUSH_PROVIDER_CONFIGURED=false

# -----------------------------------------------------------------------------
# Backend / serverless
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

APP_URL=http://localhost:5173
NODE_ENV=development
VERCEL_URL=

# Comma-separated origins, example:
# https://dealbank.io,https://www.dealbank.io
CORS_ALLOWED_ORIGINS=

# Claude / Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
CLAUDE_DEMO_MODE=false

# RapidAPI (Realty Base property intelligence)
RAPIDAPI_KEY_REALTY_BASE=
# Optional fallback alias used by the server handler
RAPIDAPI_KEY=
RAPIDAPI_REALTY_BASE_HOST=realty-base-us.p.rapidapi.com
RAPIDAPI_REALTY_BASE_QUERY_KEY=query
# Official query supports: propertyId, url, full_address, or id (e.g. address:<propertyId>)
# Keep query as the primary key and fall back through alternates below when provider responses are sparse.
RAPIDAPI_REALTY_BASE_QUERY_KEYS=query,address,propertyAddress,property_address,location,q
RAPIDAPI_REALTY_BASE_AUTOCOMPLETE_PATHS=/property/auto-complete,/property/autocomplete
RAPIDAPI_REALTY_BASE_AUTOCOMPLETE_QUERY_KEYS=query,q,address
RAPIDAPI_REALTY_BASE_DETAIL_PATHS=/property/v2/detail,/property/detail,/detail
RATE_LIMIT_PROPERTY_INTELLIGENCE_MAX=40
RATE_LIMIT_PROPERTY_INTELLIGENCE_WINDOW_MS=60000

# Stripe backend
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_ESCROW_PLATFORM_FEE_RATE=1.5

# Stripe backend price IDs
STRIPE_PRICE_CONTRACTOR_BASIC_MONTHLY=
STRIPE_PRICE_CONTRACTOR_PRO_MONTHLY=
STRIPE_PRICE_DEALMAKER_MONTHLY=
STRIPE_PRICE_REALTOR_MONTHLY=
STRIPE_PRICE_CREDITS_STARTER=
STRIPE_PRICE_CREDITS_GROWTH=
STRIPE_PRICE_CREDITS_PRO=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@dealbank.local
# Comma-separated list of domains allowed for SENDGRID_FROM_EMAIL in production
SENDGRID_VERIFIED_DOMAINS=

# Optional server-to-server service secret used for internal API calls
SERVICE_SECRET=

# Twilio backend
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_AUTH_TOKEN=
TWILIO_TWIML_APP_SID=
TWILIO_PUSH_CREDENTIAL_SID=
TWILIO_CALLER_ID=
TWILIO_SMS_FROM=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_CALL_WEBHOOK_ENDPOINT=/api/twilio-access-token?mode=call-webhook
TWILIO_SYNC_TWIML_APP=true
TWILIO_AUTO_CREATE_TWIML_APP=true
TWILIO_AUTO_RESOLVE_CALLER_ID=true
TWILIO_TWIML_APP_FRIENDLY_NAME=DealBank Voice Dialer
TWILIO_TWIML_VOICE_URL=/api/twilio-access-token?mode=twiml
TWILIO_RECORD_FROM_ANSWER=true
TWILIO_ENABLE_TRANSCRIPTION=true
TWILIO_VALIDATE_WEBHOOK_SIGNATURE=true

# Contracts / document delivery
CONTRACTS_BUCKET=contracts
CONTRACTS_SIGNING_PRIVATE_KEY_PEM=
CONTRACTS_SIGNING_CERT_PEM=
PUPPETEER_EXECUTABLE_PATH=
CONTRACT_EMAIL_RETRY_MAX_ATTEMPTS=3
CONTRACT_EMAIL_RETRY_BASE_DELAY_MS=900
CONTRACT_EMAIL_RETRY_MAX_DELAY_MS=30000
CONTRACT_EMAIL_MAX_TOTAL_ATTEMPTS=8
CONTRACT_EMAIL_RETRY_ATTEMPTS_PER_RUN=1
CONTRACT_DELIVERY_RETRY_BATCH=30
CONTRACT_DELIVERY_CRON_SECRET=
# Optional alias used by Vercel Cron Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
TITLE_PORTAL_TOKEN_TTL_HOURS=168

# Push provider credentials (server-side sender setup)
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# CSLB verification
CSLB_VERIFICATION_MODE=auto
CSLB_PROVIDER_ENDPOINT=
CSLB_PROVIDER_API_KEY=
CSLB_PUBLIC_LOOKUP_URL=https://www2.cslb.ca.gov/OnlineServices/CheckLicenseII/LicenseDetail.aspx
CSLB_CACHE_TTL_HOURS=24

# Rate limits
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

RATE_LIMIT_CLAUDE_MAX=20
RATE_LIMIT_CLAUDE_USER_MAX=20
RATE_LIMIT_CLAUDE_IP_MAX=60
RATE_LIMIT_CLAUDE_WINDOW_MS=60000

RATE_LIMIT_CHECKOUT_MAX=40
RATE_LIMIT_CHECKOUT_WINDOW_MS=60000

RATE_LIMIT_LEAD_LISTINGS_MAX=60
RATE_LIMIT_LEAD_LISTINGS_WINDOW_MS=60000

RATE_LIMIT_SEND_SMS_MAX=15
RATE_LIMIT_SEND_SMS_WINDOW_MS=60000

RATE_LIMIT_NOTIFY_CONTRACT_MAX=20
RATE_LIMIT_NOTIFY_CONTRACT_WINDOW_MS=60000

RATE_LIMIT_CSLB_MAX=30
RATE_LIMIT_CSLB_WINDOW_MS=60000

RATE_LIMIT_CLIENT_IP_MAX=120
RATE_LIMIT_CLIENT_IP_WINDOW_MS=60000

RATE_LIMIT_CONTRACT_SIGNATURE_MAX=40
RATE_LIMIT_CONTRACT_SIGNATURE_WINDOW_MS=60000

RATE_LIMIT_CONTRACT_PDF_MAX=30
RATE_LIMIT_CONTRACT_PDF_WINDOW_MS=60000

RATE_LIMIT_TITLE_PORTAL_MAX=120
RATE_LIMIT_TITLE_PORTAL_WINDOW_MS=60000

RATE_LIMIT_TITLE_PORTAL_ADMIN_MAX=60
RATE_LIMIT_TITLE_PORTAL_ADMIN_WINDOW_MS=60000

RATE_LIMIT_CONTRACT_DELIVERY_RETRY_MAX=20
RATE_LIMIT_CONTRACT_DELIVERY_RETRY_WINDOW_MS=60000

RATE_LIMIT_PUSH_TOKEN_MAX=60
RATE_LIMIT_PUSH_TOKEN_WINDOW_MS=60000

RATE_LIMIT_PARTNER_REFERRAL_MAX=120
RATE_LIMIT_PARTNER_REFERRAL_WINDOW_MS=60000

RATE_LIMIT_REALTOR_COMMISSION_REVIEW_MAX=40
RATE_LIMIT_REALTOR_COMMISSION_REVIEW_WINDOW_MS=60000

RATE_LIMIT_TWILIO_ACCESS_MAX=30
RATE_LIMIT_TWILIO_ACCESS_WINDOW_MS=60000

RATE_LIMIT_TWILIO_WEBHOOK_MAX=600
RATE_LIMIT_TWILIO_WEBHOOK_WINDOW_MS=60000

RATE_LIMIT_STRIPE_CONNECT_MAX=30
RATE_LIMIT_STRIPE_CONNECT_WINDOW_MS=60000

RATE_LIMIT_STRIPE_ESCROW_MAX=30
RATE_LIMIT_STRIPE_ESCROW_WINDOW_MS=60000

RATE_LIMIT_STRIPE_WEBHOOK_MAX=600
RATE_LIMIT_STRIPE_WEBHOOK_WINDOW_MS=60000

# Local helper scripts
SEED_AUTH_PASSWORD=
